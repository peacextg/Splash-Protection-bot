# Required
API_ID=1234567
API_HASH=your_api_hash
BOT_TOKEN=your_bot_token_from_botfather
GITHUB_TOKEN=your_github_token

# Optional
GIST_ID=                          # Set after first run (auto-created)
LOGGER_GROUP=0                    # Telegram chat ID for login logs
MAX_USERBOTS=5                    # Max connected accounts
PORT=8080                         # Render health check port
PROXY=                            # Optional proxy URL (e.g., http://user:pass@host:port)
SESSION_STRING=                   # Bot session string (auto-generated, for faster restarts)
PUBLIC_URL=                       # Render service URL (keeps free tier awake, e.g. https://your-app.onrender.com)
